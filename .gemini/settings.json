{
  "experimental": {
    "enableAgents": true
  },
  "hooks": {
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "log-before-agent",
            "type": "command",
            "command": "python3 .gemini/hooks/log.py"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "log-after-tool",
            "type": "command",
            "command": "python3 .gemini/hooks/log.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "startup",
            "type": "command",
            "command": "python3 .gemini/hooks/session.py"
          },
          {
            "name": "welcome-message",
            "type": "command",
            "command": "python3 .gemini/hooks/welcome.py"
          }
        ]
      }
    ],
    "AfterModel": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "log-model-output",
            "type": "command",
            "command": "python3 .gemini/hooks/log.py"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "*",
        "sequential": true,
        "hooks": [
          {
            "name": "notify-user",
            "type": "command",
            "command": "python3 .gemini/hooks/notify.py"
          },
          {
            "name": "log-after-agent",
            "type": "command",
            "command": "python3 .gemini/hooks/log.py"
          }
        ]
      }
    ]
  },
  "hooksConfig": {
    "disabled": []
  }
}